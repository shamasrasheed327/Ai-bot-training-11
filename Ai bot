      "source": [
        "# ==========================\n",
        "# Triple Barrier Labeling\n",
        "# ==========================\n",
        "\n",
        "for i in range(len(df) - MAX_HOLD):\n",
        "\n",
        "    entry = df[\"Close\"].iloc[i]\n",
        "\n",
        "    atr = df[\"ATR\"].iloc[i]\n",
        "\n",
        "    tp = entry + (TP_MULTIPLIER * atr)\n",
        "\n",
        "    sl = entry - (SL_MULTIPLIER * atr)\n",
        "\n",
        "    future = df.iloc[i+1:i+MAX_HOLD+1]\n",
        "\n",
        "    target = 0\n",
        "\n",
        "    for _, row in future.iterrows():\n",
        "\n",
        "        if row[\"Low\"] <= sl:\n",
        "            target = 0\n",
        "            break\n",
        "\n",
        "        if row[\"High\"] >= tp:\n",
        "            target = 1\n",
        "            break\n",
        "\n",
        "    df.loc[df.index[i], \"Target\"] = target\n",
        "\n",
        "print(\"Finished\")"
