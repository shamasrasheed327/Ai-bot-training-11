        "# ==================================\n",
        "# Create Trade Outcome Target (TP vs SL)\n",
        "# ==================================\n",
        "\n",
        "lookahead = 10\n",
        "\n",
        "df[\"Target\"] = 0\n",
        "\n",
        "for i in range(len(df) - lookahead):\n",
        "\n",
        "    tp = df[\"TP\"].iloc[i]\n",
        "    sl = df[\"SL\"].iloc[i]\n",
        "\n",
        "    future = df.iloc[i+1:i+lookahead+1]\n",
        "\n",
        "    tp_hit = (future[\"High\"] >= tp).any()\n",
        "    sl_hit = (future[\"Low\"] <= sl).any()\n",
        "\n",
        "    if tp_hit and not sl_hit:\n",
        "        df.at[df.index[i], \"Target\"] = 1\n",
        "    else:\n",
        "        df.at[df.index[i], \"Target\"] = 0\n",
        "\n",
        "print(df[[\"Close\", \"SL\", \"TP\", \"Target\"]].tail(15))\n",
        "print()\n",
