        "# Liquidity Sweep Detection\n",
        "\n",
        "def detect_liquidity_sweep(df):\n",
        "    df = df.copy()\n",
        "\n",
        "    df[\"Buy_Sweep\"] = (\n",
        "        (df[\"Low\"] < df[\"Low\"].shift(1)) &\n",
        "        (df[\"Close\"] > df[\"Low\"].shift(1))\n",
        "    )\n",
        "\n",
        "    df[\"Sell_Sweep\"] = (\n",
        "        (df[\"High\"] > df[\"High\"].shift(1)) &\n",
        "        (df[\"Close\"] < df[\"High\"].shift(1))\n",
        "    )\n",
        "\n",
        "    return df\n",
        "\n",
        "gold_data = detect_liquidity_sweep(market_data[\"XAUUSD\"])\n",
        "\n",
        "print(gold_data[[\"High\", \"Low\", \"Close\", \"Buy_Sweep\", \"Sell_Sweep\"]].tail(10))"
